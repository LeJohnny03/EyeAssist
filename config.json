{
    "camera": {
        "camera_id": 0,
        "width": 640,
        "height": 480,
        "flip_horizontal": true,
        "fps_target": 30
    },
    "tracking": {
        "max_num_faces": 1,
        "refine_landmarks": true,
        "min_detection_confidence": 0.5,
        "min_tracking_confidence": 0.5,
        "static_image_mode": false
    },
